datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Region {
  id           Int           @id @default(autoincrement())
  name         String        @unique
  distributors Distributor[]
  agents       Agent[]
  customers    Customer[]
}

model Distributor {
  id                  Int           @id @default(autoincrement())
  name                String
  regionId            Int
  region              Region        @relation(fields: [regionId], references: [id])
  agents              Agent[]       @relation("AgentToDistributor")
  customers           Customer[]

  // Self-referential loop for Sub-Distributors
  parentDistributorId Int?
  parentDistributor   Distributor?  @relation("DistributorToSubDistributor", fields: [parentDistributorId], references: [id])
  subDistributors     Distributor[] @relation("DistributorToSubDistributor")
}

model Agent {
  id            Int           @id @default(autoincrement())
  name          String
  regionId      Int
  region        Region        @relation(fields: [regionId], references: [id])
  distributors  Distributor[] @relation("AgentToDistributor")
  customers     Customer[]

  // Self-referential loop for Sub-Agents
  parentAgentId Int?
  parentAgent   Agent?        @relation("AgentToSubAgent", fields: [parentAgentId], references: [id])
  subAgents     Agent[]       @relation("AgentToSubAgent")
}

model Customer {
  id            Int          @id @default(autoincrement())
  name          String
  regionId      Int
  region        Region       @relation(fields: [regionId], references: [id])
  distributorId Int?
  distributor   Distributor? @relation(fields: [distributorId], references: [id])
  agentId       Int?
  agent         Agent?       @relation(fields: [agentId], references: [id])
}
model User {
  id       Int    @id @default(autoincrement())
  email    String @unique
  name     String
  password String
  role     String // Enforced values: "ADMIN", "MANAGER", or "STAFF"
}