datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

// 1. Regions (Includes specific regions and a "Global" option)
model Region {
  id           Int           @id @default(autoincrement())
  name         String        @unique // e.g., "North America", "Europe", "Global"
  distributors Distributor[]
  agents       Agent[]
  customers    Customer[]
}

// 2. Distributors
model Distributor {
  id        Int        @id @default(autoincrement())
  name      String
  regionId  Int
  region    Region     @relation(fields: [regionId], references: [id])
  agents    Agent[]    @relation("AgentToDistributor") // Many-to-Many matrix
  customers Customer[]
}

// 3. Agents
model Agent {
  id           Int           @id @default(autoincrement())
  name         String
  regionId     Int
  region       Region        @relation(fields: [regionId], references: [id])
  distributors Distributor[] @relation("AgentToDistributor") // Many-to-Many matrix
  customers    Customer[]
}

// 4. Customers
model Customer {
  id            Int          @id @default(autoincrement())
  name          String
  regionId      Int
  region        Region       @relation(fields: [regionId], references: [id])
  distributorId Int?
  distributor   Distributor? @relation(fields: [distributorId], references: [id])
  agentId       Int?
  agent         Agent?       @relation(fields: [agentId], references: [id])
}